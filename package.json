{
  "name": "vs-code-ext-from-any-js",
  "displayName": "any js start hooking",
  "description": "start from any js, and hook foldes",
  "publisher": "KeshavSoft",
  "type": "module",
  "version": "1.14.5",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keshavsoft/vs-code-ext-from-any-js.git"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.editor.title.routesjs.addTableName",
        "title": "AddTableName"
      },
      {
        "command": "extension.editor.title.routesjs.addTableNameHtml",
        "title": "AddTableNameHtml"
      },
      {
        "command": "extension.editor.title.frontend.addListeners.addHtmlId",
        "title": "addHtmlId"
      },
      {
        "command": "extension.editor.title.backend.appjs.start",
        "title": "startEndPoint"
      },
      {
        "command": "extension.editor.title.frontend.addListeners.headerItem",
        "title": "addHeaderItem"
      },
      {
        "command": "extension.editor.title.backend.endpointsjs.methods.post",
        "title": "postMethod"
      },
      {
        "command": "extension.explorer.right.public.init",
        "title": "InitFromScript"
      },
      {
        "command": "extension.editor.title.frontend.public.html.init",
        "title": "fillColumns"
      },
      {
        "command": "extension.editor.title.backend.endpointsjs.methods.get",
        "title": "getMethod"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.editor.title.routesjs.addTableNameHtml",
          "when": "resourceFilename == routes.js",
          "group": "navigation@2"
        },
        {
          "command": "extension.explorer.right.public.init",
          "when": "explorerResourceIsFolder && resourceFilename == Public",
          "group": "navigation@2"
        }
      ],
      "editor/context": [],
      "editor/title": [
        {
          "command": "extension.editor.title.routesjs.addTableName",
          "when": "resourceFilename == routes.js",
          "group": "navigation@2"
        },
        {
          "command": "extension.editor.title.routesjs.addTableNameHtml",
          "when": "resourceFilename == routes.js",
          "group": "navigation@3"
        },
        {
          "command": "extension.editor.title.frontend.addListeners.addHtmlId",
          "when": "resourceFilename == addListeners.js",
          "group": "navigation@3"
        },
        {
          "command": "extension.editor.title.frontend.addListeners.headerItem",
          "when": "resourceFilename == addListeners.js",
          "group": "navigation@3"
        },
        {
          "command": "extension.editor.title.backend.appjs.start",
          "when": "resourceFilename == app.js",
          "group": "navigation@3"
        },
        {
          "command": "extension.editor.title.backend.endpointsjs.methods.post",
          "when": "resourceFilename == end-points.js",
          "group": "navigation@3"
        },
        {
          "command": "extension.editor.title.frontend.public.html.init",
          "when": "resourceFilename == index.html",
          "group": "navigation@3"
        },
        {
          "command": "extension.editor.title.backend.endpointsjs.methods.get",
          "when": "resourceFilename == end-points.js",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "json-crud-ui-init": "^1.9.10",
    "kschema-api-gen-appjs": "^1.9.2",
    "kschema-api-gen-endpointsjs": "^1.7.4",
    "kschema-fs-api-gen-get-actions": "^1.10.2",
    "kschema-fs-api-gen-post-actions": "^1.19.9",
    "kschema-fs-read-config": "^1.4.8",
    "kschema-fs-ui-alter-config": "^1.5.2",
    "kschema-ui-hook-add-listeners": "^1.5.3",
    "pattern-collector-appjs-use-extract": "^1.2.1",
    "pattern-collector-routesjs-import-extract": "^1.2.2"
  }
}
